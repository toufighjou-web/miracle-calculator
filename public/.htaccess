# Miracle Financial Mortgage Calculator — Cache Control

# Never cache index.html — always fetch fresh so new JS is picked up immediately
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Cache JS and CSS files for 1 year (safe because filenames are fixed and overwritten on deploy)
<FilesMatch "\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000"
</FilesMatch>
